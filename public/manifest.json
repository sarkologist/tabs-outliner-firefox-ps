{
  "manifest_version": 3,
  "name": "Tabs Outliner",
  "version": "0.1.0",
  "description": "A durable sidebar outline of live and recently-closed tabs.",
  "permissions": ["tabs", "storage", "unlimitedStorage"],
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "background": {
    "scripts": ["background/background.js"]
  },
  "sidebar_action": {
    "default_title": "Tabs Outliner",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": "icons/icon.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tabs-outliner-rewrite@example.local",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
