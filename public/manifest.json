{
  "manifest_version": 3,
  "name": "Tabs Outliner (PS rewrite)",
  "version": "0.1.0",
  "description": "A durable sidebar outline of your live and saved tabs and windows (PureScript rewrite).",
  "permissions": ["tabs", "storage", "unlimitedStorage"],
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "background": {
    "scripts": ["background/background.js"]
  },
  "sidebar_action": {
    "default_title": "Tabs Outliner (PS rewrite)",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": "icons/icon.svg"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "commands": {
    "_execute_sidebar_action": {
      "suggested_key": {
        "windows": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      }
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tabs-outliner-rewrite@example.local",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
