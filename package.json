{
  "name": "tabs-outliner-rewrite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ps:build": "spago build",
    "ps:test": "spago test",
    "bundle": "node scripts/bundle.mjs",
    "copy-static": "node scripts/copy-static.mjs",
    "build": "spago build && node scripts/bundle.mjs && node scripts/copy-static.mjs",
    "test": "spago test",
    "test:e2e": "playwright test",
    "lint:ext": "web-ext lint --source-dir dist --no-config-discovery",
